# ------------------------------
# FastAPI service runtime config
# ------------------------------
POSTGRES_HOST=postgresql.hse-llm-project.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DB=default
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

K8S_NAMESPACE=hse-llm-project
CRD_GROUP=llm.platform
CRD_VERSION=v1alpha1
CRD_PLURAL=llmdeployments
LOG_LEVEL=INFO
SECURITY_AUTH_ENABLED=true
SECURITY_AUDIT_BASE_URL=http://security-audit-service.hse-llm-project.svc.cluster.local:8000
SECURITY_AUDIT_TIMEOUT_SECONDS=5
# Service-to-service Bearer token with audit:write permission in security service.
# Can be raw token or full "Bearer <token>" value.
SECURITY_AUDIT_SERVICE_TOKEN=demo-ci-bot-api-key-platform-v2
SECURITY_VERIFY_CACHE_TTL_SECONDS=15
SECURITY_VERIFY_CACHE_MAX_SIZE=2048
PROXY_AUDIT_INCLUDE_BODIES=true
PROXY_AUDIT_MAX_BODY_CHARS=200000
PROXY_UPSTREAM_TIMEOUT_SECONDS=180
PROXY_UPSTREAM_CPU_TIMEOUT_SECONDS=600
PROXY_UPSTREAM_GPU_TIMEOUT_SECONDS=180
PROXY_UPSTREAM_CONNECT_TIMEOUT_SECONDS=10
TRAFFIC_ROUTE_PROXY_MODE=gateway_api
TRAFFIC_ROUTE_GATEWAY_ENABLED=true
TRAFFIC_ROUTE_GATEWAY_NAME=web-gateway
TRAFFIC_ROUTE_GATEWAY_NAMESPACE=hse-llm-project
TRAFFIC_ROUTE_GATEWAY_INTERNAL_DOMAIN=hse-llm.internal
TRAFFIC_ROUTE_GATEWAY_PUBLIC_DOMAIN=hse-llm-project-2026.ru
TRAFFIC_ROUTE_GATEWAY_SERVICE_NAME=cilium-gateway-web-gateway
TRAFFIC_ROUTE_GATEWAY_SERVICE_PORT=80
TRAFFIC_ROUTE_GATEWAY_TIMEOUT_SECONDS=180
INFRASTRUCTURE_CACHE_TTL_SECONDS=5
INFRASTRUCTURE_CACHE_MAX_ENTRIES=32
DEPLOYMENTS_CACHE_TTL_SECONDS=5
DEPLOYMENTS_CACHE_MAX_ENTRIES=64
STATUS_PROMETHEUS_HISTORY_ENABLED=true
STATUS_PROMETHEUS_BASE_URL=http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090
STATUS_PROMETHEUS_TIMEOUT_SECONDS=5
STATUS_PROMETHEUS_STEP_SECONDS=30
STATUS_BLACKBOX_ENABLED=true
STATUS_BLACKBOX_SUCCESS_METRIC=probe_success
STATUS_BLACKBOX_STATUS_CODE_METRIC=probe_http_status_code
STATUS_BLACKBOX_DURATION_METRIC=probe_duration_seconds
STATUS_BLACKBOX_LOOKBACK_SECONDS=120
MEMORY_REQUEST=4Gi
CPU_MEMORY_REQUEST=6Gi
GPU_RESOURCE=nvidia.com/gpu
MAX_CPU_PER_CONTAINER_MILLICORES=8000
MAX_MODEL_LEN_HARD_LIMIT=32768
MODEL_MAX_TOKENS_OVERRIDES='huggingfacetb/smollm2-135m-instruct=4096;qwen/qwen2.5-0.5b-instruct=2048'
MODEL_MAX_LEN_CATALOG={"HuggingFaceTB/SmolLM2-135M-Instruct":4096,"Qwen/Qwen2.5-0.5B-Instruct":2048}
CPU_FEATURE_LABEL_PREFIX=feature.node.kubernetes.io/cpu-cpuid.
CPU_REQUIRED_FEATURES_DEFAULT=avx2
CPU_REQUIRED_FEATURES_OVERRIDES=
GPU_COMPUTE_MAJOR_LABEL=nvidia.com/gpu.compute.major
GPU_COMPUTE_MINOR_LABEL=nvidia.com/gpu.compute.minor
GPU_MIN_COMPUTE_CAPABILITY_DEFAULT=7.0
GPU_MIN_COMPUTE_CAPABILITY_OVERRIDES=
GPU_INFO_SOURCE=nvidia-smi-probe
GPU_PROBE_IMAGE=nvcr.io/nvidia/cuda:12.5.0-base-ubuntu22.04
GPU_PROBE_RUNTIME_CLASS_NAME=nvidia
GPU_PROBE_TIMEOUT_SECONDS=20
GPU_INFO_CACHE_TTL_SECONDS=60
CPU_MODEL_SOURCE=auto
CPU_PROBE_IMAGE=busybox:1.36.1
CPU_PROBE_TIMEOUT_SECONDS=8
TALOSCTL_PATH=talosctl
TALOSCTL_TIMEOUT_SECONDS=3
TALOSCTL_CONTEXT=
TALOSCTL_CONFIG_PATH=
CPU_MODEL_CACHE_TTL_SECONDS=60

# -------------------------------------
# Deployment scripts + Helm defaults
# -------------------------------------
IMAGE_REPOSITORY=awesomecosmonaut/deployment-service
IMAGE_TAG=latest

NAMESPACE=hse-llm-project
RELEASE_NAME=deployment-service
KUBECONFIG_PATH=/home/oleg/Documents/hse-llm-project/cluster-config/llm_proj_talos/kubeconfig
DELETE_NAMESPACE=false

# Optional overrides for scripts.
# If empty, scripts use their internal defaults based on script location.
CHART_DIR=
VALUES_FILE=
DOCKERFILE_PATH=
BUILD_CONTEXT=

# Helm values passed from scripts
POSTGRES_SECRET_NAME=
POSTGRES_SECRET_KEY=
